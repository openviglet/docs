%%{init: {'theme': 'base', 'themeVariables': {'fontSize': '13px', 'primaryColor': '#fff', 'primaryBorderColor': '#c0c0c0', 'lineColor': '#888', 'textColor': '#333'}}}%%
graph TD
    ITEM["📄 Job Item"] --> S1["⚙️ Priority 10: DeindexStrategy"]
    S1 -->|"DELETE action"| DEL["🗑️ De-index from search engine"]
    S1 -->|"Not DELETE"| S2["⚙️ Priority 20: IgnoreIndexingRuleStrategy"]
    S2 -->|"Matches rule"| IGN["⏭️ Skip (ignored)"]
    S2 -->|"No match"| S3["⚙️ Priority 30: IndexStrategy"]
    S3 -->|"New document"| IDX["📥 Index"]
    S3 -->|"Exists"| S4["⚙️ Priority 40: ReindexStrategy"]
    S4 -->|"Checksum changed"| REIDX["🔄 Re-index"]
    S4 -->|"Same checksum"| S5["⚙️ Priority 50: UnchangedStrategy"]
    S5 --> SKIP["⏭️ Skip (unchanged)"]

    classDef blue fill:#dbeafe,stroke:#4A90D9,stroke-width:2px,color:#1a1a1a
    classDef green fill:#dcfce7,stroke:#50B86C,stroke-width:2px,color:#1a1a1a
    classDef purple fill:#ede9fe,stroke:#9B6EC5,stroke-width:2px,color:#1a1a1a
    classDef amber fill:#fef3c7,stroke:#E8A838,stroke-width:2px,color:#1a1a1a

    class ITEM blue
    class S1,S2,S3,S4,S5 purple
    class IDX,REIDX green
    class DEL,IGN,SKIP amber
